<div class="container">
  <div class="row">
    <div class="col">
      <h1 class="display-4" style="text-align:center;">Posts</h1>
      <table class="table">
        <thead>
          <tr>
            <th>Date posted</th>
            <th>Network</th>
            <th>Link</th>
            <th>Name</th>
            <th>List(s)</th>
          </tr>
        </thead>
        <tbody>
          <% @posts.each do |post| %>
            <tr>
              <td><%= post[:date_posted] %></td>
              <td><%= post[:social_network] %></td>
              <td><%= post[:link] %></td>
              <td><%= post[:name] %></td>
              <td><%= post[:text] %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
